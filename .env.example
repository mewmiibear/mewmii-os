# WooCommerce REST API + webhook credentials.
# This project has no .env loader yet - these must be set as real server/hosting
# environment variables (e.g. via the hosting panel or .htaccess SetEnv), not just
# dropped in a .env file, until a loader is added.

WC_URL=
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
WC_WEBHOOK_SECRET=
